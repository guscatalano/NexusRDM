<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexusRDM.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:NexusRDM.Views"
    Title="Nexus RDM">

    <Grid>
        <NavigationView x:Name="NavView"
                        PaneDisplayMode="LeftCompact"
                        IsBackButtonVisible="Collapsed"
                        OpenPaneLength="260"
                        CompactPaneLength="48"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="connections" Icon="Network" Content="Connections" IsSelected="True" />
                <NavigationViewItem Tag="audit"       Icon="Clock"   Content="Audit Log" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="settings" Icon="Setting" Content="Settings" />
            </NavigationView.FooterMenuItems>

            <!-- Main area: left pane + splitter + tab sessions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="180" MaxWidth="420" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <views:ConnectionsPane x:Name="ConnectionsPane" Grid.Column="0" />

                <Border Grid.Column="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <TabView x:Name="SessionTabs"
                         Grid.Column="2"
                         TabWidthMode="SizeToContent"
                         IsAddTabButtonVisible="False"
                         TabCloseRequested="SessionTabs_TabCloseRequested" />
            </Grid>

        </NavigationView>
    </Grid>
</Window>
