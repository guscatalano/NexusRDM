<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexusRDM.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:NexusRDM.Views"
    Title="Nexus RDM">

    <!-- Root: dark bg matching NxBg0 -->
    <Grid Background="{StaticResource NxBg0}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom drag region / title bar -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0" Height="32"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="Nexus RDM"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource NxTx2}"
                           IsHitTestVisible="False" />
            </Grid>
        </Border>

        <!-- Main area: compact sidebar + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Compact icon sidebar (44px — matches prototype) -->
            <Border Grid.Column="0"
                    Background="{StaticResource NxBg1}"
                    BorderBrush="{StaticResource NxBrd}"
                    BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Stretch">
                    <!-- Connections -->
                    <Button x:Name="BtnNavConn"
                            Click="BtnNavConn_Click"
                            Width="36" Height="36"
                            Margin="4,6,4,2"
                            Padding="0"
                            Background="{StaticResource NxBg3}"
                            BorderThickness="0"
                            CornerRadius="6"
                            ToolTipService.ToolTip="Connections">
                        <PathIcon Data="M1,3 L7,3 L7,7 L1,7 Z M9,9 L15,9 L15,13 L9,13 Z M4,7 L4,9 L12,9"
                                  Foreground="{StaticResource NxTx1}"
                                  Width="16" Height="16" />
                    </Button>

                    <!-- Audit log -->
                    <Button x:Name="BtnNavAudit"
                            Click="BtnNavAudit_Click"
                            Width="36" Height="36"
                            Margin="4,2,4,2"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            ToolTipService.ToolTip="Audit log">
                        <FontIcon Glyph="&#xE9F9;"
                                  FontSize="15"
                                  Foreground="{StaticResource NxTx3}" />
                    </Button>

                    <Border Height="1" Background="{StaticResource NxBrd}" Margin="8,4" />

                    <!-- Settings -->
                    <Button x:Name="BtnNavSettings"
                            Click="BtnNavSettings_Click"
                            Width="36" Height="36"
                            Margin="4,2,4,2"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;"
                                  FontSize="15"
                                  Foreground="{StaticResource NxTx3}" />
                    </Button>

                    <!-- Copy XAML visual tree (diagnostic). Sits in the
                         sidebar so clicking it doesn't change which view
                         is active — the dump captures the current tree as
                         the user is seeing it. -->
                    <Button x:Name="BtnCopyVisualTree"
                            Click="BtnCopyVisualTree_Click"
                            Width="36" Height="36"
                            Margin="4,2,4,4"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="6"
                            ToolTipService.ToolTip="Copy visual tree (clipboard)">
                        <FontIcon Glyph="&#xE8C8;"
                                  FontSize="15"
                                  Foreground="{StaticResource NxTx3}" />
                        <Button.Flyout>
                            <Flyout x:Name="CopyVisualTreeFlyout">
                                <TextBlock x:Name="CopyVisualTreeStatus"
                                           Text=""
                                           FontSize="12"
                                           Foreground="{StaticResource NxTx1}" />
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Right: connections pane + tabs, or full-width pages -->
            <Grid Grid.Column="1">

                <!-- CONNECTIONS + TAB VIEW -->
                <Grid x:Name="ConnView">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="240" MinWidth="160" MaxWidth="900" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <views:ConnectionsPane x:Name="ConnectionsPane"
                                           Grid.Column="0"
                                           Background="{StaticResource NxBg1}" />

                    <!-- Hand-rolled splitter: a 4-px Border that captures
                         pointer drags and adjusts SidebarColumn.Width.
                         WinUI 3 doesn't ship a built-in GridSplitter, and
                         dragging a column boundary is a 20-line problem
                         that doesn't justify a new package. -->
                    <Border x:Name="SidebarSplitter"
                            Grid.Column="1"
                            Background="{StaticResource NxBrd}"
                            ManipulationMode="TranslateX"
                            PointerPressed="SidebarSplitter_PointerPressed"
                            PointerMoved="SidebarSplitter_PointerMoved"
                            PointerReleased="SidebarSplitter_PointerReleased"
                            PointerEntered="SidebarSplitter_PointerEntered"
                            PointerExited="SidebarSplitter_PointerExited" />

                    <!-- When collapsed: a thin reveal strip with an
                         expand button. The pane itself sits at width 0,
                         so this band has the only visible affordance. -->
                    <Border x:Name="SidebarCollapsedStrip"
                            Grid.Column="0"
                            Width="22"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            Background="{StaticResource NxBg1}"
                            BorderBrush="{StaticResource NxBrd}"
                            BorderThickness="0,0,1,0">
                        <Button Click="SidebarToggle_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0,8"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                ToolTipService.ToolTip="Show connections">
                            <FontIcon Glyph="&#xE76C;" FontSize="11"
                                      Foreground="{StaticResource NxTx2}" />
                        </Button>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource NxBrd}" />

                    <TabView x:Name="SessionTabs"
                             Grid.Column="2"
                             TabWidthMode="SizeToContent"
                             IsAddTabButtonVisible="False"
                             Background="{StaticResource NxBg0}"
                             TabCloseRequested="SessionTabs_TabCloseRequested" />
                </Grid>

                <!-- AUDIT LOG PAGE (full width) -->
                <views:AuditLogPage x:Name="AuditPage"
                                    Visibility="Collapsed"
                                    Background="{StaticResource NxBg0}" />

                <!-- SETTINGS PAGE (full width) -->
                <views:SettingsPage x:Name="SettingsPageView"
                                    Visibility="Collapsed"
                                    Background="{StaticResource NxBg0}" />

            </Grid>
        </Grid>

        <!-- Overlay host for slide-over panels — sits above the main content row -->
        <Grid x:Name="OverlayHost"
              Grid.Row="1"
              Visibility="Collapsed" />
    </Grid>
</Window>
