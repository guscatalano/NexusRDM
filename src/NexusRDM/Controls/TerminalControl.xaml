<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Controls.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Canvas-based renderer. TerminalControl.cs places TextBlock children
        for each visible glyph. Will be replaced with a Win2D SwapChainPanel
        for full colour/bold/underline support in M2 polish.
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="#0C0C0C">
        <Canvas x:Name="TermCanvas" />
    </ScrollViewer>

</UserControl>
