<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Controls.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Canvas-based renderer. TerminalControl.xaml.cs places TextBlock children
        for each visible glyph. Canvas DesiredSize is (0,0) by default so we
        size it explicitly in OnSizeChanged; otherwise nothing would be visible.
    -->
    <Border Background="#0C0C0C">
        <Canvas x:Name="TermCanvas"
                HorizontalAlignment="Left"
                VerticalAlignment="Top" />
    </Border>

</UserControl>
