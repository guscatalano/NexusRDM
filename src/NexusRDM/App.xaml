<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NexusRDM.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NexusRDM.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Nexus color tokens (match prototype-v1) ── -->
            <Color x:Key="NxBg0Color">#FF1A1A1F</Color>
            <Color x:Key="NxBg1Color">#FF22222A</Color>
            <Color x:Key="NxBg2Color">#FF2A2A38</Color>
            <Color x:Key="NxBg3Color">#FF2E2E3E</Color>
            <Color x:Key="NxAccentColor">#FF7C6EF7</Color>
            <Color x:Key="NxAccent2Color">#FFA599FF</Color>
            <Color x:Key="NxSshColor">#FF3DD68C</Color>
            <Color x:Key="NxRdpColor">#FF4DA6FF</Color>
            <Color x:Key="NxTx1Color">#FFE8E8F0</Color>
            <Color x:Key="NxTx2Color">#FF808090</Color>
            <Color x:Key="NxTx3Color">#FF404050</Color>
            <Color x:Key="NxBrdColor">#30FFFFFF</Color>
            <Color x:Key="NxRedColor">#FFFF6B6B</Color>
            <Color x:Key="NxYellowColor">#FFF0A732</Color>

            <SolidColorBrush x:Key="NxBg0" Color="{StaticResource NxBg0Color}" />
            <SolidColorBrush x:Key="NxBg1" Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="NxBg2" Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="NxBg3" Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="NxAccent" Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="NxAccent2" Color="{StaticResource NxAccent2Color}" />
            <SolidColorBrush x:Key="NxSsh" Color="{StaticResource NxSshColor}" />
            <SolidColorBrush x:Key="NxRdp" Color="{StaticResource NxRdpColor}" />
            <SolidColorBrush x:Key="NxTx1" Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="NxTx2" Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="NxTx3" Color="{StaticResource NxTx3Color}" />
            <SolidColorBrush x:Key="NxBrd" Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="NxRed" Color="{StaticResource NxRedColor}" />
            <SolidColorBrush x:Key="NxYellow" Color="{StaticResource NxYellowColor}" />

            <!-- Override WinUI defaults to match dark theme -->
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource NxBg0Color}" />
            <SolidColorBrush x:Key="TabViewBackground" Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{StaticResource NxBg0Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{StaticResource NxTx1Color}" />

            <!-- Value converters app-wide -->
            <conv:InvertBoolConverter       x:Key="InvertBoolConverter" />
            <conv:NonZeroToBoolConverter    x:Key="NonZeroToBoolConverter" />
            <conv:SshVisibilityConverter    x:Key="SshVisibilityConverter" />
            <conv:RdpVisibilityConverter    x:Key="RdpVisibilityConverter" />
            <conv:PrivKeyVisibilityConverter x:Key="PrivKeyVisibilityConverter" />

            <!-- Shared styles -->
            <Style x:Key="NxTreeItemStyle" TargetType="TreeViewItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinHeight" Value="28" />
            </Style>

            <Style x:Key="StatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource NxTx2}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
