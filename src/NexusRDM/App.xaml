<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NexusRDM.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NexusRDM.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Nexus color tokens (match prototype-v1) ── -->
            <Color x:Key="NxBg0Color">#FF1A1A1F</Color>
            <Color x:Key="NxBg1Color">#FF22222A</Color>
            <Color x:Key="NxBg2Color">#FF2A2A38</Color>
            <Color x:Key="NxBg3Color">#FF2E2E3E</Color>
            <Color x:Key="NxAccentColor">#FF7C6EF7</Color>
            <Color x:Key="NxAccent2Color">#FFA599FF</Color>
            <Color x:Key="NxSshColor">#FF3DD68C</Color>
            <Color x:Key="NxRdpColor">#FF4DA6FF</Color>
            <Color x:Key="NxTx1Color">#FFE8E8F0</Color>
            <Color x:Key="NxTx2Color">#FF808090</Color>
            <Color x:Key="NxTx3Color">#FF404050</Color>
            <Color x:Key="NxBrdColor">#30FFFFFF</Color>
            <Color x:Key="NxRedColor">#FFFF6B6B</Color>
            <Color x:Key="NxYellowColor">#FFF0A732</Color>

            <SolidColorBrush x:Key="NxBg0" Color="{StaticResource NxBg0Color}" />
            <SolidColorBrush x:Key="NxBg1" Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="NxBg2" Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="NxBg3" Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="NxAccent" Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="NxAccent2" Color="{StaticResource NxAccent2Color}" />
            <SolidColorBrush x:Key="NxSsh" Color="{StaticResource NxSshColor}" />
            <SolidColorBrush x:Key="NxRdp" Color="{StaticResource NxRdpColor}" />
            <SolidColorBrush x:Key="NxTx1" Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="NxTx2" Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="NxTx3" Color="{StaticResource NxTx3Color}" />
            <SolidColorBrush x:Key="NxBrd" Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="NxRed" Color="{StaticResource NxRedColor}" />
            <SolidColorBrush x:Key="NxYellow" Color="{StaticResource NxYellowColor}" />

            <!-- Override WinUI defaults to match dark theme -->
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource NxBg0Color}" />
            <SolidColorBrush x:Key="TabViewBackground" Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{StaticResource NxBg0Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{StaticResource NxTx1Color}" />

            <!-- ContentDialog: dark surface, sharp border, no acrylic -->
            <SolidColorBrush x:Key="ContentDialogBackground"           Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="ContentDialogForeground"           Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ContentDialogBorderBrush"          Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="ContentDialogTopOverlay"           Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="ContentDialogSeparatorBorderBrush" Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="ContentDialogSmokeFill"            Color="#80000000" />
            <Thickness x:Key="ContentDialogBorderWidth">1</Thickness>

            <!-- TextBox / PasswordBox / NumberBox -->
            <SolidColorBrush x:Key="TextControlBackground"               Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver"    Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused"        Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="TextControlBackgroundDisabled"       Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="TextControlForeground"               Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="TextControlForegroundPointerOver"    Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="TextControlForegroundFocused"        Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="TextControlForegroundDisabled"       Color="{StaticResource NxTx3Color}" />
            <SolidColorBrush x:Key="TextControlBorderBrush"              Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"   Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused"       Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="TextControlPlaceholderForeground"    Color="{StaticResource NxTx3Color}" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"     Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="TextControlHeaderForeground"         Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="TextControlButtonBackground"         Color="Transparent" />
            <SolidColorBrush x:Key="TextControlButtonForeground"         Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="TextControlButtonForegroundPointerOver" Color="{StaticResource NxTx1Color}" />

            <!-- ComboBox -->
            <SolidColorBrush x:Key="ComboBoxBackground"               Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"    Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed"        Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundFocused"        Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"       Color="{StaticResource NxBg1Color}" />
            <SolidColorBrush x:Key="ComboBoxForeground"               Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ComboBoxForegroundPointerOver"    Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ComboBoxForegroundPressed"        Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ComboBoxForegroundFocused"        Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush"              Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver"   Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushFocused"       Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackground"               Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerOver"    Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush"              Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="ComboBoxItemBackground"               Color="Transparent" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver"    Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected"       Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ComboBoxItemForeground"               Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected"       Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ComboBoxPlaceHolderForeground"        Color="{StaticResource NxTx3Color}" />

            <!-- Buttons (close + default) -->
            <SolidColorBrush x:Key="ButtonBackground"            Color="{StaticResource NxBg2Color}" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="{StaticResource NxBg3Color}" />
            <SolidColorBrush x:Key="ButtonForeground"            Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="ButtonBorderBrush"           Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource NxBrdColor}" />

            <!-- AccentButton (PrimaryButton in dialogs) -->
            <SolidColorBrush x:Key="AccentButtonBackground"            Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="{StaticResource NxAccent2Color}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed"     Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="AccentButtonForeground"            Color="White" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="AccentButtonBorderBrush"           Color="{StaticResource NxAccentColor}" />

            <!-- CheckBox -->
            <SolidColorBrush x:Key="CheckBoxForegroundUnchecked"            Color="{StaticResource NxTx2Color}" />
            <SolidColorBrush x:Key="CheckBoxForegroundUncheckedPointerOver" Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="CheckBoxForegroundChecked"              Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUnchecked"   Color="Transparent" />
            <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked"     Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked"   Color="{StaticResource NxAccentColor}" />
            <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked"    Color="White" />

            <!-- InfoBar (error banner) -->
            <SolidColorBrush x:Key="InfoBarErrorSeverityBackgroundBrush" Color="#33FF6B6B" />
            <SolidColorBrush x:Key="InfoBarBorderBrush"                  Color="{StaticResource NxBrdColor}" />
            <SolidColorBrush x:Key="InfoBarTitleForeground"              Color="{StaticResource NxTx1Color}" />
            <SolidColorBrush x:Key="InfoBarMessageForeground"            Color="{StaticResource NxTx1Color}" />

            <!-- Value converters app-wide -->
            <conv:InvertBoolConverter       x:Key="InvertBoolConverter" />
            <conv:NonZeroToBoolConverter    x:Key="NonZeroToBoolConverter" />
            <conv:SshVisibilityConverter    x:Key="SshVisibilityConverter" />
            <conv:RdpVisibilityConverter    x:Key="RdpVisibilityConverter" />
            <conv:PrivKeyVisibilityConverter x:Key="PrivKeyVisibilityConverter" />
            <conv:DirectoryGlyphConverter   x:Key="DirectoryGlyphConv" />
            <conv:BytesToHumanConverter     x:Key="BytesConv" />

            <!-- Shared styles -->
            <Style x:Key="NxTreeItemStyle" TargetType="TreeViewItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinHeight" Value="28" />
            </Style>

            <Style x:Key="StatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource NxTx2}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
