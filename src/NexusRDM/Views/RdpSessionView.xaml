<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.RdpSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <Grid Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1" Padding="8,4" ColumnDefinitions="Auto,*,Auto,Auto">

            <FontIcon Grid.Column="0" Glyph="&#xE8AF;" FontSize="14" Margin="0,0,8,0"
                      VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.Host, Mode=OneTime}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="Ctrl+Alt+Del" Margin="8,0"
                    Click="SendCtrlAltDel_Click" />
            <Button Grid.Column="3" Content="Disconnect"
                    Command="{x:Bind ViewModel.DisconnectCommand}" />
        </Grid>

        <!-- HWND host panel for mstsc.exe child window -->
        <Border x:Name="RdpHostPanel" Grid.Row="1" Background="#000000"
                SizeChanged="RdpHostPanel_SizeChanged" />

        <!-- Status bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Padding="8,4">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
                <ProgressRing Grid.Column="1"
                              IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                              Width="16" Height="16" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
