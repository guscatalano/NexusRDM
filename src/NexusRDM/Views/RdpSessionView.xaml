<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.RdpSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource NxBg0}"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <Grid RowDefinitions="30,*,22">

        <!-- Session toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="10,0">
                <Ellipse Grid.Column="0" Width="7" Height="7"
                         Fill="{StaticResource NxRdp}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" x:Name="HostLabel"
                           FontSize="12"
                           Foreground="{StaticResource NxTx2}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="3"
                        Click="SendCtrlAltDel_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        Content="Ctrl+Alt+Del"
                        Margin="0,0,6,0" />
                <Button Grid.Column="4"
                        Command="{x:Bind ViewModel.DisconnectCommand}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        Content="Disconnect" />
            </Grid>
        </Border>

        <!-- RDP HWND host — black panel, mstsc reparents on top of it.
             The status overlay sits underneath so it's visible during the
             1.5s mstsc spin-up and also remains as a fallback if reparenting
             fails (mstsc Phase 1 is brittle — see RdpSession.cs). -->
        <Grid Grid.Row="1">
            <Border x:Name="RdpHostPanel"
                    Background="#000000"
                    SizeChanged="RdpHostPanel_SizeChanged" />
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        IsHitTestVisible="False">
                <ProgressRing IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                              Width="28" Height="28"
                              Foreground="{StaticResource NxAccent}" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="13"
                           Foreground="{StaticResource NxTx2}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="If the desktop doesn't appear here, look for the Remote Desktop window in the taskbar."
                           FontSize="11"
                           Foreground="{StaticResource NxTx3}"
                           TextWrapping="Wrap"
                           MaxWidth="360"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="#1E1E28"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="10,0">
                <TextBlock Grid.Column="0" Text="RDP"
                           Style="{StaticResource StatusTextStyle}" Margin="0,0,14,0" />
                <TextBlock Grid.Column="1" Text="1920×1080"
                           Style="{StaticResource StatusTextStyle}" />
                <ProgressRing Grid.Column="3"
                              IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                              Width="14" Height="14"
                              Foreground="{StaticResource NxAccent}"
                              Margin="0,0,8,0" />
                <TextBlock Grid.Column="4" x:Name="HostStatusLabel"
                           Style="{StaticResource StatusTextStyle}" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
