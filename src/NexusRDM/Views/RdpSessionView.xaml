<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.RdpSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusRDM.ViewModels"
    Background="{StaticResource NxBg0}"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <Grid x:Name="RootGrid" RowDefinitions="30,*,22"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          MinHeight="400">

        <!-- Session toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="10,0">
                <Ellipse Grid.Column="0" Width="7" Height="7"
                         Fill="{StaticResource NxRdp}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" x:Name="HostLabel"
                           FontSize="12"
                           Foreground="{StaticResource NxTx2}"
                           VerticalAlignment="Center" />
                <!-- SmartSizing checkbox: when checked, the remote desktop
                     scales to fit the host window. When unchecked, the
                     OCX renders at its negotiated resolution and you get
                     scrollbars if it's larger than the host. -->
                <CheckBox Grid.Column="3"
                          IsChecked="{x:Bind ViewModel.SmartSizing, Mode=TwoWay}"
                          Content="Fit to window"
                          ToolTipService.ToolTip="When unchecked the remote desktop renders at its native resolution (with scrollbars)."
                          FontSize="11"
                          Foreground="{StaticResource NxTx2}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0" />
                <!-- Resolution dropdown: live-resizes the remote session via
                     IMsRdpClient9.UpdateSessionDisplaySettings without
                     reconnecting. Empty by default so the initial
                     negotiated size (DesktopWidth/Height) wins. -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{x:Bind ViewModel.Resolutions}"
                          SelectedItem="{x:Bind ViewModel.SelectedResolution, Mode=TwoWay}"
                          PlaceholderText="Resolution"
                          ToolTipService.ToolTip="Renegotiate the remote session resolution"
                          FontSize="11"
                          MinWidth="160"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate xmlns:m="using:NexusRDM.Core.Models" x:DataType="m:RdpDefaultResolution">
                            <TextBlock Text="{x:Bind vm:RdpSessionViewModel.FormatResolution((m:RdpDefaultResolution))}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="5"
                        Click="FullScreen_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Full screen (Ctrl+Alt+Break to exit)"
                        Content="Full screen"
                        Margin="0,0,6,0" />
                <Button Grid.Column="6"
                        Click="PopOut_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Detach into its own resizable window"
                        Content="Pop out"
                        Margin="0,0,6,0" />
                <Button Grid.Column="7"
                        Click="SendCtrlAltDel_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        Content="Ctrl+Alt+Del"
                        Margin="0,0,6,0" />
                <Button Grid.Column="8"
                        Click="Events_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Open the live event log for this session"
                        Content="RDP events"
                        Margin="0,0,6,0" />
                <!-- Disconnect/Connect toggle: visibility flips on the
                     ViewModel's IsDisconnected flag (= !IsConnected &&
                     !IsConnecting). Both buttons live in the same column;
                     only one is laid out at a time. -->
                <Button Grid.Column="9"
                        Command="{x:Bind ViewModel.DisconnectCommand}"
                        Visibility="{x:Bind ViewModel.IsActive, Mode=OneWay}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        Content="Disconnect" />
                <Button Grid.Column="9"
                        Command="{x:Bind ViewModel.ConnectCommand}"
                        Visibility="{x:Bind ViewModel.IsDisconnected, Mode=OneWay}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        Content="Connect" />
            </Grid>
        </Border>

        <!-- Follow-the-window tab body: the embedded mstscax form is a
             top-level window pinned over RdpHostPanel's screen rect by a
             50 ms poll in code-behind. RdpHostPanel itself is just a
             placeholder so XAML knows where the form should sit. The
             status overlay only shows while IsConnecting flips; the
             disconnected overlay shows when IsDisconnected (form has been
             torn down, panel area is empty). -->
        <Grid Grid.Row="1">
            <Border x:Name="RdpHostPanel"
                    Background="#0F0F12"
                    SizeChanged="RdpHostPanel_SizeChanged" />

            <!-- Demo-mode fake desktop. Visible only when the
                 underlying session is a DemoRdpSession (vm.IsDemo).
                 Painted entirely in XAML primitives so we don't need
                 a binary asset. The big "DEMO" watermark + obvious
                 "fake desktop" copy makes it impossible to mistake
                 for a real session, even at a glance in the README. -->
            <Grid IsHitTestVisible="False"
                  Visibility="{x:Bind ViewModel.IsDemo, Mode=OneWay}">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B3A6B" Offset="0" />
                        <GradientStop Color="#2A5BA8" Offset="0.55" />
                        <GradientStop Color="#3D7AC4" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Center "monitor" card with the fake desktop content. -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16"
                            Margin="40">
                    <TextBlock Text="DEMO"
                               FontSize="96"
                               FontWeight="Bold"
                               Foreground="#80FFFFFF"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Simulated RDP session"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Demo mode shows a placeholder image instead of opening a real connection. Exit demo mode to use the real RDP backend."
                               FontSize="13"
                               Foreground="#CCFFFFFF"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="480"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Fake taskbar at the bottom. Just enough chrome
                     that the placeholder reads as "a Windows desktop"
                     at a glance — no functional buttons. -->
                <Border VerticalAlignment="Bottom"
                        Height="40"
                        Background="#CC1A1A1A"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="48,*,Auto" Margin="6,0,12,0">
                        <Border Grid.Column="0"
                                Width="32" Height="32"
                                CornerRadius="4"
                                Background="#FF0078D4"
                                VerticalAlignment="Center">
                            <TextBlock Text="⊞"
                                       FontSize="20"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="2"
                                   Text="DEMO  |  10:45 AM"
                                   FontSize="12"
                                   Foreground="#CCFFFFFF"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        IsHitTestVisible="False"
                        Visibility="{x:Bind ViewModel.IsConnecting, Mode=OneWay}">
                <ProgressRing IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                              Width="28" Height="28"
                              Foreground="{StaticResource NxAccent}" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="13"
                           Foreground="{StaticResource NxTx2}"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14"
                        Visibility="{x:Bind ViewModel.IsDisconnected, Mode=OneWay}">
                <!-- Segoe Fluent Icons F384 = NetworkOffline. Big and dim
                     so it reads as "this slot is empty" rather than an
                     actionable error. -->
                <FontIcon Glyph="&#xF384;"
                          FontSize="56"
                          Foreground="{StaticResource NxTx3}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="Disconnected"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource NxTx1}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           FontSize="12"
                           Foreground="{StaticResource NxTx3}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="420"
                           TextAlignment="Center" />
                <Button Command="{x:Bind ViewModel.ConnectCommand}"
                        Background="{StaticResource NxAccent}"
                        BorderThickness="0"
                        CornerRadius="4"
                        Padding="16,6"
                        FontSize="12"
                        Foreground="White"
                        Content="Reconnect"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="#1E1E28"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="10,0">
                <TextBlock Grid.Column="0" Text="RDP"
                           Style="{StaticResource StatusTextStyle}" Margin="0,0,14,0" />
                <TextBlock Grid.Column="1" Text="1920×1080"
                           Style="{StaticResource StatusTextStyle}" />
                <ProgressRing Grid.Column="3"
                              IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                              Width="14" Height="14"
                              Foreground="{StaticResource NxAccent}"
                              Margin="0,0,8,0" />
                <TextBlock Grid.Column="4" x:Name="HostStatusLabel"
                           Style="{StaticResource StatusTextStyle}" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
