<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.EditConnectionPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusRDM.ViewModels"
    xmlns:models="using:NexusRDM.Core.Models"
    xmlns:conv="using:NexusRDM.Converters">

    <!-- Full-bleed scrim + right-anchored panel -->
    <Grid Background="#80000000" Tapped="OnScrimTapped">

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="440"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="1,0,0,0"
                Tapped="OnPanelTapped">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{StaticResource NxBg1}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="0,0,0,1"
                        Padding="20,14,12,14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Configure how Nexus connects to this host."
                                       FontSize="11"
                                       Foreground="{StaticResource NxTx3}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Click="OnCancelClick"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8"
                                ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="12"
                                      Foreground="{StaticResource NxTx2}" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Body -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16,20,16">
                    <StackPanel x:Name="BodyStack" Spacing="6">

                        <!-- Error banner: selectable so the user can copy the message. -->
                        <Border Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"
                                Background="#33FF6B6B"
                                BorderBrush="#80FF6B6B"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,8">
                            <Grid ColumnDefinitions="Auto,*">
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE783;"
                                          FontSize="14"
                                          Foreground="{StaticResource NxRed}"
                                          VerticalAlignment="Top"
                                          Margin="0,2,8,0" />
                                <TextBox  Grid.Column="1"
                                          Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                          IsReadOnly="True"
                                          AcceptsReturn="True"
                                          TextWrapping="Wrap"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          Padding="0"
                                          FontSize="12"
                                          Foreground="{StaticResource NxTx1}" />
                            </Grid>
                        </Border>

                        <TextBlock Text="GENERAL"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource NxTx3}"
                                   Margin="0,4,0,2" />

                        <TextBox Header="Display name" PlaceholderText="e.g. Production Web Server"
                                 Text="{x:Bind ViewModel.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}" />

                        <ComboBox Header="Protocol" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.ProtocolOptions}"
                                  DisplayMemberPath="Display"
                                  SelectedItem="{x:Bind ViewModel.SelectedProtocolOption, Mode=TwoWay}" />

                        <Grid ColumnDefinitions="*,Auto,110">
                            <TextBox Grid.Column="0" Header="Host / IP"
                                     PlaceholderText="hostname or 192.168.x.x"
                                     Text="{x:Bind ViewModel.Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Bottom" Margin="6,0,6,8"
                                       Foreground="{StaticResource NxTx2}" />
                            <NumberBox Grid.Column="2" Header="Port" Minimum="1" Maximum="65535"
                                       SpinButtonPlacementMode="Compact"
                                       Value="{x:Bind ViewModel.Port, Mode=TwoWay}" />
                        </Grid>

                        <ComboBox Header="Group" HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.GroupOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{x:Bind ViewModel.SelectedGroupOption, Mode=TwoWay}" />

                        <TextBox Header="Tags (comma separated)" PlaceholderText="linux, production, web"
                                 Text="{x:Bind ViewModel.Tags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- Per-connection icon picker. The selection is
                             stored as a Segoe Fluent Icons codepoint on
                             ConnectionProfile.IconGlyph. The picker renders
                             a small grid of toggle buttons so the user
                             can scan and pick visually. The icon is
                             optional — "None" clears the choice. -->
                        <TextBlock Text="ICON"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource NxTx3}"
                                   Margin="0,12,0,2" />
                        <Button Click="IconNone_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="6,2"
                                FontSize="11"
                                Foreground="{StaticResource NxTx2}"
                                ToolTipService.ToolTip="No icon"
                                Content="None"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,6" />
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.IconChoices}"
                                       xmlns:svc="using:NexusRDM.Services">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="40" MinItemHeight="40"
                                                   MinRowSpacing="6" MinColumnSpacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="svc:IconChoice">
                                    <Button Tag="{x:Bind Glyph}"
                                            ToolTipService.ToolTip="{x:Bind Name}"
                                            Click="IconChoice_Click"
                                            Background="{StaticResource NxBg2}"
                                            BorderBrush="{StaticResource NxBrd}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Width="36" Height="36"
                                            Padding="0">
                                        <FontIcon Glyph="{x:Bind Glyph}"
                                                  FontSize="14"
                                                  Foreground="{StaticResource NxTx1}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- SSH section: credentials + ssh-specific options -->
                        <StackPanel Spacing="6"
                                    Visibility="{x:Bind ViewModel.Protocol, Mode=OneWay, Converter={StaticResource SshVisibilityConverter}}">
                            <TextBlock Text="SSH"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,12,0,2" />
                            <TextBox Header="Username"
                                     Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox Header="Authentication method" HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.SshAuthOptions}"
                                      DisplayMemberPath="Display"
                                      SelectedItem="{x:Bind ViewModel.SelectedSshAuthOption, Mode=TwoWay}" />
                            <!-- Password — masked PasswordBox + plaintext TextBox toggle.
                                 Both bound to ViewModel.Password so the value
                                 stays in sync regardless of which is visible. -->
                            <Grid Visibility="{x:Bind ViewModel.SshAuthMethod, Mode=OneWay, Converter={StaticResource PrivKeyVisibilityConverter}, ConverterParameter=Invert}">
                                <PasswordBox Header="Password"
                                             Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{x:Bind ViewModel.PasswordBoxVisibility, Mode=OneWay}" />
                                <TextBox Header="Password"
                                         Text="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                         Visibility="{x:Bind ViewModel.PasswordTextBoxVisibility, Mode=OneWay}" />
                            </Grid>
                            <CheckBox Content="Show password"
                                      IsChecked="{x:Bind ViewModel.ShowPassword, Mode=TwoWay}"
                                      Visibility="{x:Bind ViewModel.SshAuthMethod, Mode=OneWay, Converter={StaticResource PrivKeyVisibilityConverter}, ConverterParameter=Invert}" />
                            <TextBox Header="Private key path (.pem / .ppk)"
                                     PlaceholderText="C:\Users\you\.ssh\id_rsa"
                                     Text="{x:Bind ViewModel.PrivateKeyPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{x:Bind ViewModel.SshAuthMethod, Mode=OneWay, Converter={StaticResource PrivKeyVisibilityConverter}}" />

                            <!-- Credential storage status + save toggle.
                                 The status line tells the user whether a password
                                 is currently in the Windows Credential Manager;
                                 the checkbox controls whether saving happens on
                                 the next Save click. -->
                            <TextBlock Text="{x:Bind ViewModel.CredentialStatusText, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{StaticResource NxTx2}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <CheckBox Content="Don't save — prompt at connect time"
                                      IsChecked="{x:Bind ViewModel.SaveCredential, Mode=TwoWay, Converter={StaticResource InvertBoolConverter}}" />
                            <NumberBox Header="Keep-alive interval (seconds)" Minimum="0" Maximum="300"
                                       SpinButtonPlacementMode="Compact"
                                       Value="{x:Bind ViewModel.KeepAliveSeconds, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- RDP section: credentials + rdp-specific options -->
                        <StackPanel Spacing="6"
                                    Visibility="{x:Bind ViewModel.Protocol, Mode=OneWay, Converter={StaticResource RdpVisibilityConverter}}">
                            <TextBlock Text="RDP"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,12,0,2" />
                            <TextBox Header="Domain (optional)"
                                     Text="{x:Bind ViewModel.RdpDomain, Mode=TwoWay}" />
                            <TextBox Header="Username"
                                     Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid>
                                <PasswordBox Header="Password"
                                             Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{x:Bind ViewModel.PasswordBoxVisibility, Mode=OneWay}" />
                                <TextBox Header="Password"
                                         Text="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                         Visibility="{x:Bind ViewModel.PasswordTextBoxVisibility, Mode=OneWay}" />
                            </Grid>
                            <CheckBox Content="Show password"
                                      IsChecked="{x:Bind ViewModel.ShowPassword, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.CredentialStatusText, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{StaticResource NxTx2}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <CheckBox Content="Don't save — prompt at connect time"
                                      IsChecked="{x:Bind ViewModel.SaveCredential, Mode=TwoWay, Converter={StaticResource InvertBoolConverter}}" />

                            <TextBlock Text="DISPLAY"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,8,0,2" />
                            <ComboBox Header="Resolution" HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.RdpResolutionOptions}"
                                      DisplayMemberPath="Display"
                                      SelectedItem="{x:Bind ViewModel.SelectedRdpResolutionOption, Mode=TwoWay}" />
                            <CheckBox Content="Full screen" IsChecked="{x:Bind ViewModel.RdpFullScreen, Mode=TwoWay}" />
                            <ComboBox Header="Color depth" HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.RdpColorDepthOptions}"
                                      DisplayMemberPath="Display"
                                      SelectedItem="{x:Bind ViewModel.SelectedRdpColorDepthOption, Mode=TwoWay}" />

                            <TextBlock Text="REDIRECTIONS"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,12,0,2" />
                            <CheckBox Content="Clipboard"        IsChecked="{x:Bind ViewModel.RdpClipboard,  Mode=TwoWay}" />
                            <CheckBox Content="Local drives"     IsChecked="{x:Bind ViewModel.RdpDrives,     Mode=TwoWay}" />
                            <CheckBox Content="Printers"         IsChecked="{x:Bind ViewModel.RdpPrinters,   Mode=TwoWay}" />
                            <CheckBox Content="Smart cards"      IsChecked="{x:Bind ViewModel.RdpSmartCards, Mode=TwoWay}" />
                            <CheckBox Content="Serial / COM ports" IsChecked="{x:Bind ViewModel.RdpPorts,    Mode=TwoWay}" />
                            <CheckBox Content="Plug-and-play devices (cameras, phones)" IsChecked="{x:Bind ViewModel.RdpDevices,    Mode=TwoWay}" />
                            <CheckBox Content="Point-of-sale devices" IsChecked="{x:Bind ViewModel.RdpPosDevices, Mode=TwoWay}" />

                            <TextBlock Text="AUDIO"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,12,0,2" />
                            <ComboBox Header="Playback" HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.RdpAudioOptions}"
                                      DisplayMemberPath="Display"
                                      SelectedItem="{x:Bind ViewModel.SelectedRdpAudioOption, Mode=TwoWay}" />
                            <CheckBox Content="Redirect microphone" IsChecked="{x:Bind ViewModel.RdpAudioCapture, Mode=TwoWay}" />

                            <TextBlock Text="GATEWAY"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,12,0,2" />
                            <ComboBox Header="Usage" HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.RdpGatewayUsageOptions}"
                                      DisplayMemberPath="Display"
                                      SelectedItem="{x:Bind ViewModel.SelectedRdpGatewayUsageOption, Mode=TwoWay}" />
                            <TextBox Header="Gateway server"   PlaceholderText="rdgw.example.com"
                                     Text="{x:Bind ViewModel.RdpGatewayServer,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="Gateway username" PlaceholderText="(blank to use session creds)"
                                     Text="{x:Bind ViewModel.RdpGatewayUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Header="Gateway domain"
                                     Text="{x:Bind ViewModel.RdpGatewayDomain,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- Advanced — every remaining knob the OCX
                                 surfaces. Collapsed by default so the
                                 panel doesn't intimidate first-time
                                 users. -->
                            <Expander Header="Advanced"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Margin="0,12,0,0">
                                <StackPanel Spacing="6" Padding="0,4,0,0">

                                    <TextBlock Text="AUTHENTICATION"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NxTx3}" />
                                    <ComboBox Header="Server-auth strictness" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.RdpAuthLevelOptions}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{x:Bind ViewModel.SelectedRdpAuthLevelOption, Mode=TwoWay}" />
                                    <CheckBox Content="Enable Network-Level Auth (CredSSP)" IsChecked="{x:Bind ViewModel.RdpEnableCredSsp,   Mode=TwoWay}" />
                                    <CheckBox Content="Always prompt for credentials"        IsChecked="{x:Bind ViewModel.RdpPromptForCreds,  Mode=TwoWay}" />
                                    <CheckBox Content="Connect to admin / console session"   IsChecked="{x:Bind ViewModel.RdpAdminConsole,    Mode=TwoWay}" />

                                    <TextBlock Text="PERFORMANCE"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NxTx3}"
                                               Margin="0,8,0,2" />
                                    <ComboBox Header="Network connection type" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.RdpNetworkOptions}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{x:Bind ViewModel.SelectedRdpNetworkOption, Mode=TwoWay}" />
                                    <CheckBox Content="Show desktop background"   IsChecked="{x:Bind ViewModel.RdpDesktopBackground,  Mode=TwoWay}" />
                                    <CheckBox Content="Visual styles (themes)"    IsChecked="{x:Bind ViewModel.RdpVisualStyles,       Mode=TwoWay}" />
                                    <CheckBox Content="Font smoothing"            IsChecked="{x:Bind ViewModel.RdpFontSmoothing,      Mode=TwoWay}" />
                                    <CheckBox Content="Menu / window animations" IsChecked="{x:Bind ViewModel.RdpMenuAnimations,     Mode=TwoWay}" />
                                    <CheckBox Content="Show window contents while dragging" IsChecked="{x:Bind ViewModel.RdpWindowDrag, Mode=TwoWay}" />
                                    <CheckBox Content="Desktop composition (Aero)" IsChecked="{x:Bind ViewModel.RdpDesktopComposition, Mode=TwoWay}" />
                                    <CheckBox Content="Persistent bitmap cache"    IsChecked="{x:Bind ViewModel.RdpBitmapCaching,      Mode=TwoWay}" />

                                    <TextBlock Text="KEYBOARD"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NxTx3}"
                                               Margin="0,8,0,2" />
                                    <ComboBox Header="Windows key combos go to" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.RdpKeyboardHookOptions}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{x:Bind ViewModel.SelectedRdpKeyboardHookOption, Mode=TwoWay}" />

                                    <TextBlock Text="CONNECTION BAR"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NxTx3}"
                                               Margin="0,8,0,2" />
                                    <CheckBox Content="Show connection bar (full screen)" IsChecked="{x:Bind ViewModel.RdpConnectionBar,    Mode=TwoWay}" />
                                    <CheckBox Content="Pin connection bar"                IsChecked="{x:Bind ViewModel.RdpPinConnectionBar, Mode=TwoWay}" />

                                    <TextBlock Text="MISC"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource NxTx3}"
                                               Margin="0,8,0,2" />
                                    <CheckBox Content="Auto-reconnect on transient drop" IsChecked="{x:Bind ViewModel.RdpAutoReconnect, Mode=TwoWay}" />
                                    <TextBox Header="Load-balance info (broker token)"
                                             PlaceholderText="tsv://MS Terminal Services Plugin.1.RDPSession"
                                             Text="{x:Bind ViewModel.RdpLoadBalanceInfo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: setting-search box on the left, action buttons on the right. -->
                <Border Grid.Row="2"
                        Background="{StaticResource NxBg1}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="0,1,0,0"
                        Padding="20,12,20,14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBox Grid.Column="0"
                                 x:Name="SearchBox"
                                 PlaceholderText="Filter settings…"
                                 TextChanged="OnSearchTextChanged"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Cancel" Click="OnCancelClick" />
                            <Button Content="Save"   Click="OnSaveClick"
                                    Style="{StaticResource AccentButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}" />
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
