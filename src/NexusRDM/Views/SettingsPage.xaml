<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexusRDM.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource NxBg0}">

    <Grid ColumnDefinitions="150,1,*">

        <!-- Left nav: search box + section list. Selecting an item
             filters the body to that section; the search box scopes
             both the list and the body. -->
        <Border Grid.Column="0"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,1,0">
            <StackPanel Padding="0,8">
                <TextBox x:Name="NavSearchBox"
                         PlaceholderText="Search…"
                         TextChanged="NavSearch_TextChanged"
                         FontSize="11"
                         Margin="8,0,8,8" />
                <ListBox x:Name="SettingsNav"
                         SelectionChanged="SettingsNav_SelectionChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectedIndex="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="14,7" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Foreground" Value="{StaticResource NxTx2}" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="2,0,0,0" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <!-- Tag = section header text (uppercase) the
                         body uses; "ALL" is a sentinel for "show
                         everything". -->
                    <ListBoxItem Content="All"               Tag="ALL" />
                    <ListBoxItem Content="Appearance"        Tag="APPEARANCE" />
                    <ListBoxItem Content="SSH defaults"      Tag="SSH DEFAULTS" />
                    <ListBoxItem Content="RDP defaults"      Tag="RDP DEFAULTS" />
                    <ListBoxItem Content="RDP backend paths" Tag="RDP BACKEND PATHS" />
                    <ListBoxItem Content="Host ping"         Tag="HOST PING" />
                    <ListBoxItem Content="Hotkeys"           Tag="HOTKEYS" />
                    <ListBoxItem Content="Safety"            Tag="SAFETY" />
                    <ListBoxItem Content="About"             Tag="ABOUT" />
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource NxBrd}" />

        <!-- Settings body -->
        <ScrollViewer Grid.Column="2" Padding="20,16,20,20">
            <StackPanel x:Name="BodyStack" Spacing="0" MaxWidth="500">

                <!-- Appearance section -->
                <TextBlock Text="APPEARANCE"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,0,0,10" />

                <!-- Font size — applied as a uniform scale on the main
                     window content; small/medium/large maps to 0.85×/1.0×/1.15×. -->
                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Font size (experimental)" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Walks the visual tree and rescales each control's FontSize. Some controls retemplate their own text and won't pick up the change — this knob is a work in progress." FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{x:Bind ViewModel.FontSizeIndex, Mode=TwoWay}"
                                  Background="{StaticResource NxBg2}"
                                  BorderBrush="{StaticResource NxBrd}"
                                  Foreground="{StaticResource NxTx1}"
                                  FontSize="12"
                                  MinWidth="120">
                            <ComboBoxItem Content="Small" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="Large" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Theme row -->
                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Theme" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Color palette — applied immediately for live preview." FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{x:Bind ViewModel.Themes}"
                                  SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Background="{StaticResource NxBg2}"
                                  BorderBrush="{StaticResource NxBrd}"
                                  Foreground="{StaticResource NxTx1}"
                                  FontSize="12"
                                  MinWidth="180" />
                    </Grid>
                </Border>

                <!-- Custom-theme editor: visible only when "Custom" is the
                     active theme. Each row is a label + a clickable swatch
                     that opens a ColorPicker flyout. Edits are persisted
                     and live-applied on every change. -->
                <Border BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="0,0,0,1"
                        Padding="0,8"
                        Visibility="{x:Bind ViewModel.CustomThemeVisibility, Mode=OneWay}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Edit custom palette" FontSize="12" Foreground="{StaticResource NxTx1}" />
                        <TextBlock Text="Click any swatch to open a color picker." FontSize="11" Foreground="{StaticResource NxTx3}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CustomColors}"
                                      xmlns:svc="using:NexusRDM.Services">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="svc:CustomColorEntry">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Name}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource NxTx1}"
                                                   VerticalAlignment="Center" />
                                        <DropDownButton Grid.Column="1"
                                                        Background="{StaticResource NxBg2}"
                                                        BorderBrush="{StaticResource NxBrd}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        MinWidth="120">
                                            <Border Width="100" Height="18"
                                                    CornerRadius="2"
                                                    Background="{x:Bind Brush, Mode=OneWay}" />
                                            <DropDownButton.Flyout>
                                                <Flyout>
                                                    <ColorPicker Color="{x:Bind Color, Mode=TwoWay}"
                                                                 ColorSpectrumShape="Box"
                                                                 IsMoreButtonVisible="True"
                                                                 IsColorSliderVisible="True"
                                                                 IsAlphaEnabled="True" />
                                                </Flyout>
                                            </DropDownButton.Flyout>
                                        </DropDownButton>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- SSH Defaults section -->
                <TextBlock Text="SSH DEFAULTS"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,10" />

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Default username" FontSize="12" Foreground="{StaticResource NxTx1}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{x:Bind ViewModel.DefaultSshUser, Mode=TwoWay}"
                                 Background="{StaticResource NxBg2}"
                                 BorderBrush="{StaticResource NxBrd}"
                                 Foreground="{StaticResource NxTx1}"
                                 FontSize="12"
                                 Width="120"
                                 CornerRadius="5" />
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Keep-alive interval" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Seconds between keepalive packets" FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" />
                        </StackPanel>
                        <NumberBox Grid.Column="1"
                                   Value="{x:Bind ViewModel.DefaultSshPort, Mode=TwoWay}"
                                   Minimum="0" Maximum="300"
                                   SpinButtonPlacementMode="Compact"
                                   Background="{StaticResource NxBg2}"
                                   BorderBrush="{StaticResource NxBrd}"
                                   Foreground="{StaticResource NxTx1}"
                                   FontSize="12"
                                   Width="90" />
                    </Grid>
                </Border>

                <!-- RDP Defaults section -->
                <TextBlock Text="RDP DEFAULTS"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,10" />

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Launch mode" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Mstsc launches Remote Desktop as a separate process. MstscAx hosts the RDP ActiveX control in-process. FreeRDP is reserved for a future cross-platform backend." />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{x:Bind ViewModel.RdpModeIndex, Mode=TwoWay}"
                                  Background="{StaticResource NxBg2}"
                                  BorderBrush="{StaticResource NxBrd}"
                                  Foreground="{StaticResource NxTx1}"
                                  FontSize="12"
                                  MinWidth="160"
                                  VerticalAlignment="Top">
                            <ComboBoxItem Content="Mstsc (separate process)" />
                            <ComboBoxItem Content="MstscAx (in-process ActiveX)" />
                            <ComboBoxItem Content="FreeRDP (not yet implemented)" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Default resolution" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Desktop size negotiated at connect time. 'Match current monitor' uses the monitor hosting the app window. The toolbar dropdown overrides this for an open session." />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{x:Bind ViewModel.RdpResolutionIndex, Mode=TwoWay}"
                                  Background="{StaticResource NxBg2}"
                                  BorderBrush="{StaticResource NxBrd}"
                                  Foreground="{StaticResource NxTx1}"
                                  FontSize="12"
                                  MinWidth="200"
                                  VerticalAlignment="Top">
                            <ComboBoxItem Content="Match current monitor" />
                            <ComboBoxItem Content="Match panel size" />
                            <ComboBoxItem Content="1024 × 768" />
                            <ComboBoxItem Content="1280 × 720" />
                            <ComboBoxItem Content="1366 × 768" />
                            <ComboBoxItem Content="1600 × 900" />
                            <ComboBoxItem Content="1920 × 1080" />
                            <ComboBoxItem Content="2560 × 1440" />
                            <ComboBoxItem Content="3840 × 2160" />
                        </ComboBox>
                    </Grid>
                </Border>

                <TextBlock Text="RDP BACKEND PATHS"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,10" />

                <!-- mstsc.exe override -->
                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="mstsc.exe path" FontSize="12" Foreground="{StaticResource NxTx1}" />
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource NxTx3}"
                                   TextWrapping="Wrap"
                                   Text="Override the system Remote Desktop client. Leave empty to use the mstsc.exe on PATH." />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.MstscExePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="(system default)"
                                     FontSize="12" />
                            <Button Grid.Column="1" Content="Browse…" Click="BrowseMstscExe_Click" FontSize="11" />
                            <Button Grid.Column="2" Content="Validate"
                                    Command="{x:Bind ViewModel.ValidateMstscExeCommand}"
                                    FontSize="11" />
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.MstscExeStatus, Mode=OneWay}"
                                   FontSize="11" Foreground="{StaticResource NxTx2}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- mstscax.dll override -->
                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="mstscax.dll path" FontSize="12" Foreground="{StaticResource NxTx1}" />
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource NxTx3}"
                                   TextWrapping="Wrap"
                                   Text="Side-loads a custom Remote Desktop ActiveX via a SxS activation context — the override DLL is used for new sessions instead of the system mstscax. Empty falls back to the system registration. Validate runs DllGetClassObject + CreateInstance to confirm the DLL really supplies MsRdpClient9." />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.MstscAxPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="(system default)"
                                     FontSize="12" />
                            <Button Grid.Column="1" Content="Browse…" Click="BrowseMstscAx_Click" FontSize="11" />
                            <Button Grid.Column="2" Content="Validate"
                                    Command="{x:Bind ViewModel.ValidateMstscAxCommand}"
                                    FontSize="11" />
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.MstscAxStatus, Mode=OneWay}"
                                   FontSize="11" Foreground="{StaticResource NxTx2}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Text="HOST PING"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,10" />

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ping connections" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Periodically pings every saved host with ICMP and shows a small status icon next to it." />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.PingEnabled, Mode=TwoWay}"
                                      OnContent="" OffContent="" />
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ping interval (seconds)" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Floored at 5 seconds." FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" />
                        </StackPanel>
                        <NumberBox Grid.Column="1"
                                   Value="{x:Bind ViewModel.PingIntervalSeconds, Mode=TwoWay}"
                                   Minimum="5" Maximum="3600"
                                   SpinButtonPlacementMode="Compact"
                                   Background="{StaticResource NxBg2}"
                                   BorderBrush="{StaticResource NxBrd}"
                                   Foreground="{StaticResource NxTx1}"
                                   FontSize="12"
                                   Width="100" />
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Show latency next to icon" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Displays the round-trip time when the host responded." FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.PingShowLatency, Mode=TwoWay}"
                                      OnContent="" OffContent="" />
                    </Grid>
                </Border>

                <TextBlock Text="HOTKEYS"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,10" />

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource NxTx3}"
                                   TextWrapping="Wrap"
                                   Text="Use combos like 'Ctrl+Tab', 'Ctrl+Shift+P', or 'F11'. Modifiers: Ctrl, Shift, Alt, Win." />
                        <!-- Each row: [enable checkbox] [label] [combo TextBox].
                             Unticking the checkbox stops the accelerator from
                             registering on the next RebuildHotkeys() call;
                             the TextBox dims to show the entry is inactive. -->
                        <Grid ColumnDefinitions="Auto,180,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                            <CheckBox  Grid.Row="0" Grid.Column="0"
                                       IsChecked="{x:Bind ViewModel.HotkeyNextTabEnabled, Mode=TwoWay}"
                                       MinWidth="0" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Next tab"        FontSize="12" Foreground="{StaticResource NxTx1}" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="0" Grid.Column="2" FontSize="12"
                                       IsEnabled="{x:Bind ViewModel.HotkeyNextTabEnabled, Mode=OneWay}"
                                       Text="{x:Bind ViewModel.HotkeyNextTab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox  Grid.Row="1" Grid.Column="0"
                                       IsChecked="{x:Bind ViewModel.HotkeyPrevTabEnabled, Mode=TwoWay}"
                                       MinWidth="0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Previous tab"    FontSize="12" Foreground="{StaticResource NxTx1}" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="1" Grid.Column="2" FontSize="12"
                                       IsEnabled="{x:Bind ViewModel.HotkeyPrevTabEnabled, Mode=OneWay}"
                                       Text="{x:Bind ViewModel.HotkeyPrevTab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox  Grid.Row="2" Grid.Column="0"
                                       IsChecked="{x:Bind ViewModel.HotkeyFullScreenEnabled, Mode=TwoWay}"
                                       MinWidth="0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Toggle full screen" FontSize="12" Foreground="{StaticResource NxTx1}" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="2" Grid.Column="2" FontSize="12"
                                       IsEnabled="{x:Bind ViewModel.HotkeyFullScreenEnabled, Mode=OneWay}"
                                       Text="{x:Bind ViewModel.HotkeyFullScreen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox  Grid.Row="3" Grid.Column="0"
                                       IsChecked="{x:Bind ViewModel.HotkeyPopOutEnabled, Mode=TwoWay}"
                                       MinWidth="0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Toggle pop out"  FontSize="12" Foreground="{StaticResource NxTx1}" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="3" Grid.Column="2" FontSize="12"
                                       IsEnabled="{x:Bind ViewModel.HotkeyPopOutEnabled, Mode=OneWay}"
                                       Text="{x:Bind ViewModel.HotkeyPopOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="SAFETY"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,10" />

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Debug mode" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Show developer tools in the sidebar — currently the &quot;Copy visual tree&quot; button. Off by default." />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.DebugMode, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent="" />
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Click behavior" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Single- or double-click in the connection list to open." FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  SelectedIndex="{x:Bind ViewModel.ClickBehaviorIndex, Mode=TwoWay}"
                                  Background="{StaticResource NxBg2}"
                                  BorderBrush="{StaticResource NxBrd}"
                                  Foreground="{StaticResource NxTx1}"
                                  FontSize="12"
                                  MinWidth="160">
                            <ComboBoxItem Content="Single-click to connect" />
                            <ComboBoxItem Content="Double-click to connect" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Audit log retention (days)" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock Text="Older entries are deleted at app startup. Default 7." FontSize="11" Foreground="{StaticResource NxTx3}" Margin="0,2,0,0" />
                        </StackPanel>
                        <NumberBox Grid.Column="1"
                                   Value="{x:Bind ViewModel.AuditRetentionDays, Mode=TwoWay}"
                                   Minimum="1" Maximum="365"
                                   SpinButtonPlacementMode="Compact"
                                   Background="{StaticResource NxBg2}"
                                   BorderBrush="{StaticResource NxBrd}"
                                   Foreground="{StaticResource NxTx1}"
                                   FontSize="12"
                                   Width="90" />
                    </Grid>
                </Border>

                <Border BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1" Padding="0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Confirm close while connected" FontSize="12" Foreground="{StaticResource NxTx1}" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource NxTx3}"
                                       Margin="0,2,0,0"
                                       TextWrapping="Wrap"
                                       Text="Prompt before closing a tab or the app while a session is still live. Disable for fast tear-down." />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.ConfirmCloseActive, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent="" />
                    </Grid>
                </Border>

                <!-- Settings auto-persist on every change; no Save button. -->
                <TextBlock Text="Changes are saved automatically."
                           FontSize="11" FontStyle="Italic"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,16,0,0" />

                <!-- About -->
                <TextBlock Text="ABOUT"
                           FontSize="10" CharacterSpacing="60"
                           Foreground="{StaticResource NxTx3}"
                           Margin="0,24,0,10" />

                <StackPanel Orientation="Horizontal" Spacing="8" Padding="0,4">
                    <TextBlock Text="Nexus RDM" FontSize="13" FontWeight="Medium" Foreground="{StaticResource NxTx1}" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneTime}"
                               FontSize="11" Foreground="{StaticResource NxTx3}" VerticalAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
