<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.SshSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NexusRDM.Controls"
    Background="{StaticResource NxBg0}">

    <Grid RowDefinitions="30,*,22">

        <!-- Session toolbar — dark bar matching prototype -->
        <Border Grid.Row="0"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="10,0">
                <!-- Green connected dot -->
                <Ellipse Grid.Column="0" Width="7" Height="7"
                         Fill="{StaticResource NxSsh}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <!-- Host label -->
                <TextBlock Grid.Column="1"
                           x:Name="HostLabel"
                           FontSize="12"
                           Foreground="{StaticResource NxTx2}"
                           VerticalAlignment="Center" />
                <!-- Connecting ring -->
                <ProgressRing Grid.Column="2"
                              IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                              Width="14" Height="14"
                              Foreground="{StaticResource NxAccent}"
                              HorizontalAlignment="Left"
                              Margin="10,0,0,0" />
                <!-- Disconnect button -->
                <Button Grid.Column="3"
                        Command="{x:Bind ViewModel.DisconnectCommand}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,2"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        Content="Disconnect" />
            </Grid>
        </Border>

        <!-- Terminal — dark #0d0d0e background, monospace -->
        <controls:TerminalControl x:Name="Terminal" Grid.Row="1"
                                  FontFamily="Cascadia Code, Consolas, Courier New"
                                  FontSize="13"
                                  Background="#0d0d0e" />

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="#1E1E28"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="10,0">
                <TextBlock Grid.Column="0" Text="SSH"
                           Style="{StaticResource StatusTextStyle}" Margin="0,0,14,0" />
                <TextBlock Grid.Column="1" x:Name="SizeLabel"
                           Style="{StaticResource StatusTextStyle}" />
                <TextBlock Grid.Column="3" x:Name="HostStatusLabel"
                           Style="{StaticResource StatusTextStyle}" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
