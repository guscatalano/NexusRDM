<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.SshSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NexusRDM.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Session toolbar -->
        <Grid Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1" Padding="8,4" ColumnDefinitions="Auto,*,Auto,Auto">

            <FontIcon Grid.Column="0" Glyph="&#xE704;" FontSize="14" Margin="0,0,8,0"
                      VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.Host, Mode=OneTime}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center" />
            <ProgressRing Grid.Column="2"
                          IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                          Width="16" Height="16" Margin="8,0" />
            <Button Grid.Column="3" Content="Disconnect"
                    Command="{x:Bind ViewModel.DisconnectCommand}"
                    Style="{ThemeResource DefaultButtonStyle}" />
        </Grid>

        <!-- Terminal surface -->
        <controls:TerminalControl x:Name="Terminal" Grid.Row="1"
                                  FontFamily="Cascadia Code, Consolas, Courier New"
                                  FontSize="14" />

        <!-- Status bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Padding="8,4">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="SizeLabel" Grid.Column="1"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
