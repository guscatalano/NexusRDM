<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NexusRDM.Views.RdpEventsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:NexusRDM.Core.Interfaces">

    <Grid Background="{StaticResource NxBg0}" RowDefinitions="34,*,28">

        <Border Grid.Row="0"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" Margin="10,0">
                <TextBlock x:Name="HeaderLabel"
                           Grid.Column="0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource NxTx1}"
                           VerticalAlignment="Center"
                           Text="RDP events" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6">
                    <Button Click="Copy_Click"
                            Background="{StaticResource NxBg2}"
                            BorderBrush="{StaticResource NxBrd}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,2"
                            FontSize="11"
                            Foreground="{StaticResource NxTx2}"
                            ToolTipService.ToolTip="Copy selected rows (or all if none selected) to the clipboard"
                            Content="Copy" />
                    <Button Click="Clear_Click"
                            Background="{StaticResource NxBg2}"
                            BorderBrush="{StaticResource NxBrd}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,2"
                            FontSize="11"
                            Foreground="{StaticResource NxTx2}"
                            Content="Clear" />
                </StackPanel>
            </Grid>
        </Border>

        <ListView x:Name="EventsList"
                  Grid.Row="1"
                  Background="{StaticResource NxBg0}"
                  Foreground="{StaticResource NxTx2}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  SelectionMode="Extended"
                  IsRightTapEnabled="True"
                  RightTapped="EventsList_RightTapped">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="10,2" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:RdpEventEntry">
                    <Grid ColumnDefinitions="80,140,*">
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind TimeText, Mode=OneTime}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{StaticResource NxTx3}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Kind, Mode=OneTime}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource NxAccent}" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Detail, Mode=OneTime}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{StaticResource NxTx2}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2"
                Background="#1E1E28"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusLabel"
                       Margin="10,0"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource NxTx3}" />
        </Border>
    </Grid>
</Window>
