<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexusRDM.Views.AuditLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NexusRDM.Core.Models">

    <Grid RowDefinitions="Auto,*">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="16,12">
            <TextBlock Text="Audit Log" Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
            <AutoSuggestBox Width="240" PlaceholderText="Filter…" QueryIcon="Find"
                            Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Refresh" Command="{x:Bind ViewModel.LoadCommand}" />
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="20" Height="20" />
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                  SelectionMode="None" Padding="8,0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:AuditEntry">
                    <Grid ColumnDefinitions="140,100,*,180" Padding="4,6">
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind OccurredAt}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Action}"
                                   Style="{ThemeResource BodyTextBlockStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind DisplayName}"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind Detail}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
