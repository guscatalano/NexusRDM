<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NexusRDM.Views.AuditLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NexusRDM.Core.Models"
    Background="{StaticResource NxBg0}">

    <Grid RowDefinitions="48,Auto,*">

        <Border Grid.Row="0"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Audit log"
                           FontSize="14" FontWeight="Medium"
                           Foreground="{StaticResource NxTx1}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <AutoSuggestBox Width="180"
                                    PlaceholderText="Filter events…"
                                    QueryIcon="Find"
                                    Background="{StaticResource NxBg2}"
                                    BorderBrush="{StaticResource NxBrd}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Foreground="{StaticResource NxTx1}"
                                    FontSize="12"
                                    Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{x:Bind ViewModel.LoadCommand}"
                            Background="{StaticResource NxBg2}"
                            BorderBrush="{StaticResource NxBrd}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="8,4"
                            FontSize="11"
                            Foreground="{StaticResource NxTx2}">
                        <FontIcon Glyph="&#xE72C;" FontSize="11" />
                    </Button>
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="18" Height="18"
                                  Foreground="{StaticResource NxAccent}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="130,90,200,*"
              Padding="16,5"
              BorderBrush="{StaticResource NxBrd}"
              BorderThickness="0,0,0,1">
            <TextBlock Grid.Column="0" Text="TIME"       FontSize="10" Foreground="{StaticResource NxTx3}" CharacterSpacing="60" />
            <TextBlock Grid.Column="1" Text="ACTION"     FontSize="10" Foreground="{StaticResource NxTx3}" CharacterSpacing="60" />
            <TextBlock Grid.Column="2" Text="CONNECTION" FontSize="10" Foreground="{StaticResource NxTx3}" CharacterSpacing="60" />
            <TextBlock Grid.Column="3" Text="DETAIL"     FontSize="10" Foreground="{StaticResource NxTx3}" CharacterSpacing="60" />
        </Grid>

        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                  SelectionMode="None"
                  Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="16,6" />
                    <Setter Property="BorderBrush" Value="{StaticResource NxBrd}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:AuditEntry">
                    <Grid ColumnDefinitions="130,90,200,*">
                        <TextBlock Grid.Column="0" Text="{x:Bind OccurredAt}"
                                   FontSize="12" Foreground="{StaticResource NxTx2}"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1" Background="#202030" CornerRadius="3"
                                Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <TextBlock Text="{x:Bind Action}"
                                       FontSize="11" Foreground="{StaticResource NxTx2}" />
                        </Border>
                        <TextBlock Grid.Column="2" Text="{x:Bind DisplayName}"
                                   FontSize="12" Foreground="{StaticResource NxTx1}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="3" Text="{x:Bind Detail}"
                                   FontSize="11" Foreground="{StaticResource NxTx2}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
