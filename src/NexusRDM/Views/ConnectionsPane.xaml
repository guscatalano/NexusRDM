<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.ConnectionsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusRDM.ViewModels"
    Background="{StaticResource NxBg1}">

    <Grid RowDefinitions="Auto,Auto,*">

        <StackPanel Grid.Row="0" Spacing="6" Padding="8,8,8,0">
            <AutoSuggestBox
                PlaceholderText="Search  Ctrl+F"
                QueryIcon="Find"
                Background="{StaticResource NxBg2}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="1"
                CornerRadius="6"
                Foreground="{StaticResource NxTx1}"
                FontSize="12"
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Command="{x:Bind ViewModel.NewConnectionCommand}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE710;" FontSize="10" />
                        <TextBlock Text="New" />
                    </StackPanel>
                </Button>
                <Button Click="NewGroup_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Create a new group">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8B7;" FontSize="10" />
                        <TextBlock Text="Group" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="11" />
                </Button>
                <!-- Tree-symbol legend. Opens a flyout that maps every
                     glyph / pill in the tree to plain-English meaning
                     so users don't have to guess what PVE / HV / the
                     coloured dots are. -->
                <Button x:Name="LegendButton"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="What do the symbols mean?">
                    <FontIcon Glyph="&#xE9CE;" FontSize="11" />
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <StackPanel Spacing="6" MaxWidth="320">
                                <TextBlock Text="Tree symbols"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource NxTx1}"
                                           Margin="0,0,0,2" />

                                <!-- Power state -->
                                <TextBlock Text="Power state (managed VMs)"
                                           FontSize="10" CharacterSpacing="60"
                                           Foreground="{StaticResource NxTx3}" />
                                <Grid ColumnDefinitions="20,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                                    <FontIcon Grid.Row="0" Grid.Column="0" Glyph="&#xE768;" FontSize="11"
                                              Foreground="#FF3DD68C" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Running"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <FontIcon Grid.Row="1" Grid.Column="0" Glyph="&#xE71A;" FontSize="11"
                                              Foreground="#FFA0A0B0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Stopped / Off"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <FontIcon Grid.Row="2" Grid.Column="0" Glyph="&#xE769;" FontSize="11"
                                              Foreground="#FFF0A732" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Paused"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <!-- Source pills -->
                                <TextBlock Text="Source pills"
                                           FontSize="10" CharacterSpacing="60"
                                           Foreground="{StaticResource NxTx3}"
                                           Margin="0,4,0,0" />
                                <Grid ColumnDefinitions="40,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource NxAccent}"
                                            CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                        <TextBlock Text="PVE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource NxTx1}" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Imported from a Proxmox cluster"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource NxAccent}"
                                            CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                        <TextBlock Text="HV" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource NxTx1}" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Imported from local Hyper-V"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource NxAccent}"
                                            CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                        <TextBlock Text="AUTO" FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource NxTx1}" />
                                    </Border>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="Folder owned by a sync — can't be deleted from here"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                </Grid>

                                <!-- Protocol badges -->
                                <TextBlock Text="Protocol badge"
                                           FontSize="10" CharacterSpacing="60"
                                           Foreground="{StaticResource NxTx3}"
                                           Margin="0,4,0,0" />
                                <Grid ColumnDefinitions="40,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                                    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource NxBg2}"
                                            CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                        <TextBlock Text="SSH" FontSize="10"
                                                   Foreground="{StaticResource NxTx3}" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="SSH terminal session"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource NxBg2}"
                                            CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                        <TextBlock Text="RDP" FontSize="10"
                                                   Foreground="{StaticResource NxTx3}" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Remote Desktop session"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <!-- Ping -->
                                <TextBlock Text="Reachability dot &amp; latency"
                                           FontSize="10" CharacterSpacing="60"
                                           Foreground="{StaticResource NxTx3}"
                                           Margin="0,4,0,0" />
                                <Grid ColumnDefinitions="20,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="3">
                                    <Ellipse Grid.Row="0" Grid.Column="0" Width="6" Height="6"
                                             Fill="#FF3DD68C" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Reachable (ping ok)"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <Ellipse Grid.Row="1" Grid.Column="0" Width="6" Height="6"
                                             Fill="#FFFF6B6B" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Unreachable (ping failed)"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <Ellipse Grid.Row="2" Grid.Column="0" Width="6" Height="6"
                                             Fill="#FFF0A732" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Pinging…"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="?"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource NxTx3}"
                                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="No measurement yet"
                                               FontSize="11" Foreground="{StaticResource NxTx2}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="CollapseButton"
                        Click="Collapse_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Hide connections list">
                    <FontIcon Glyph="&#xE76B;" FontSize="11" />
                </Button>
            </StackPanel>
        </StackPanel>

        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     Foreground="{StaticResource NxAccent}"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <!-- Horizontal scroller around the tree so very wide rows
             (long display names + multiple badges + ping latency) can
             scroll into view when the user prefers a narrow pane.
             Vertical scrolling is unchanged — TreeView keeps its own
             vertical virtualization. -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Disabled">
        <TreeView x:Name="ConnectionTree"
                  ItemsSource="{x:Bind ViewModel.RootItems, Mode=OneWay}"
                  SelectionMode="Single"
                  ItemInvoked="ConnectionTree_ItemInvoked"
                  DoubleTapped="ConnectionTree_DoubleTapped"
                  IsDoubleTapEnabled="True"
                  RightTapped="ConnectionTree_RightTapped"
                  CanDragItems="True"
                  CanReorderItems="True"
                  AllowDrop="True"
                  DragItemsCompleted="ConnectionTree_DragItemsCompleted"
                  Background="Transparent"
                  Padding="0,4,0,4">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionTreeNode">
                    <TreeViewItem ItemsSource="{x:Bind Children}"
                                  IsExpanded="True"
                                  Padding="0,2,8,2"
                                  MinHeight="28">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                                      Visibility="{x:Bind IconVisibility, Mode=OneWay}"
                                      FontSize="13"
                                      VerticalAlignment="Center">
                                <FontIcon.Foreground>
                                    <SolidColorBrush Color="{x:Bind IconColor, Mode=OneWay}" />
                                </FontIcon.Foreground>
                            </FontIcon>
                            <!-- Power-state glyph — placed left of the
                                 name so it reads as a leading status
                                 indicator instead of trailing
                                 metadata. ToolTip surfaces the state
                                 in plain words ("Running" / "Stopped"
                                 / "Paused") so the icon's meaning is
                                 obvious on hover. -->
                            <FontIcon Glyph="{x:Bind PowerStateGlyph, Mode=OneWay}"
                                      Visibility="{x:Bind PowerStateVisibility, Mode=OneWay}"
                                      FontSize="11"
                                      VerticalAlignment="Center"
                                      ToolTipService.ToolTip="{x:Bind PowerStateTooltip, Mode=OneWay}">
                                <FontIcon.Foreground>
                                    <SolidColorBrush Color="{x:Bind PowerStateColor, Mode=OneWay}" />
                                </FontIcon.Foreground>
                            </FontIcon>
                            <TextBlock Text="{x:Bind DisplayName}"
                                       FontSize="12"
                                       FontWeight="{x:Bind DisplayNameFontWeight}"
                                       FontStyle="{x:Bind DisplayNameFontStyle}"
                                       Foreground="{StaticResource NxTx1}"
                                       VerticalAlignment="Center" />
                            <!-- AUTO pill on group rows that are
                                 externally managed (Proxmox sync,
                                 auto-discovery). Pairs with italic name
                                 to make "you don't own this folder"
                                 readable at a glance. -->
                            <Border Background="{StaticResource NxAccent}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Visibility="{x:Bind AutoManagedBadgeVisibility, Mode=OneWay}"
                                    ToolTipService.ToolTip="Auto-managed — this folder is owned by a service (Proxmox sync or network discovery) and can't be deleted from the tree.">
                                <TextBlock Text="AUTO"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource NxTx1}" />
                            </Border>
                            <Border Background="{StaticResource NxBg2}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Visibility="{x:Bind BadgeVisibility}">
                                <TextBlock Text="{x:Bind BadgeText}"
                                           FontSize="10"
                                           Foreground="{StaticResource NxTx3}" />
                            </Border>
                            <!-- Power-state glyph moved to the left of
                                 the display name above — this slot
                                 used to host it. -->

                            <!-- Managed-by-source pill. Text is per-
                                 source ("PVE" / "HV") so users can
                                 tell at a glance which integration
                                 owns a row. -->
                            <Border Background="{StaticResource NxAccent}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Visibility="{x:Bind ManagedBadgeVisibility, Mode=OneWay}"
                                    ToolTipService.ToolTip="Imported by a sync integration — managed automatically. PVE = Proxmox, HV = Hyper-V.">
                                <TextBlock Text="{x:Bind ManagedBadgeText, Mode=OneWay}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource NxTx1}" />
                            </Border>
                            <!-- Ping status icon. Color comes from the
                                 PingState enum and only renders when ping
                                 is enabled in settings. -->
                            <Ellipse Width="6" Height="6"
                                     VerticalAlignment="Center"
                                     Visibility="{x:Bind PingIconVisibility, Mode=OneWay}">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{x:Bind PingIconColor, Mode=OneWay}" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{x:Bind LatencyText, Mode=OneWay}"
                                       Visibility="{x:Bind LatencyVisibility, Mode=OneWay}"
                                       FontSize="10"
                                       Foreground="{StaticResource NxTx3}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
        </ScrollViewer>

    </Grid>
</UserControl>
