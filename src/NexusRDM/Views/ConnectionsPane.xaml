<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.ConnectionsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusRDM.ViewModels"
    Background="{StaticResource NxBg1}">

    <Grid RowDefinitions="Auto,Auto,*">

        <StackPanel Grid.Row="0" Spacing="6" Padding="8,8,8,0">
            <AutoSuggestBox
                PlaceholderText="Search  Ctrl+F"
                QueryIcon="Find"
                Background="{StaticResource NxBg2}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="1"
                CornerRadius="6"
                Foreground="{StaticResource NxTx1}"
                FontSize="12"
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Command="{x:Bind ViewModel.NewConnectionCommand}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE710;" FontSize="10" />
                        <TextBlock Text="New" />
                    </StackPanel>
                </Button>
                <Button Click="NewGroup_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Create a new group">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8B7;" FontSize="10" />
                        <TextBlock Text="Group" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshCommand}"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}">
                    <FontIcon Glyph="&#xE72C;" FontSize="11" />
                </Button>
                <Button x:Name="CollapseButton"
                        Click="Collapse_Click"
                        Background="{StaticResource NxBg2}"
                        BorderBrush="{StaticResource NxBrd}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="8,4"
                        FontSize="11"
                        Foreground="{StaticResource NxTx2}"
                        ToolTipService.ToolTip="Hide connections list">
                    <FontIcon Glyph="&#xE76B;" FontSize="11" />
                </Button>
            </StackPanel>
        </StackPanel>

        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     Foreground="{StaticResource NxAccent}"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <TreeView Grid.Row="2"
                  x:Name="ConnectionTree"
                  ItemsSource="{x:Bind ViewModel.RootItems, Mode=OneWay}"
                  SelectionMode="Single"
                  ItemInvoked="ConnectionTree_ItemInvoked"
                  DoubleTapped="ConnectionTree_DoubleTapped"
                  IsDoubleTapEnabled="True"
                  RightTapped="ConnectionTree_RightTapped"
                  Background="Transparent"
                  Padding="0,4,0,4">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionTreeNode">
                    <TreeViewItem ItemsSource="{x:Bind Children}"
                                  IsExpanded="True"
                                  Padding="0,2,8,2"
                                  MinHeight="28">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                                      Visibility="{x:Bind IconVisibility, Mode=OneWay}"
                                      FontSize="13"
                                      VerticalAlignment="Center">
                                <FontIcon.Foreground>
                                    <SolidColorBrush Color="{x:Bind IconColor, Mode=OneWay}" />
                                </FontIcon.Foreground>
                            </FontIcon>
                            <TextBlock Text="{x:Bind DisplayName}"
                                       FontSize="12"
                                       FontWeight="{x:Bind DisplayNameFontWeight}"
                                       Foreground="{StaticResource NxTx1}"
                                       VerticalAlignment="Center" />
                            <Border Background="{StaticResource NxBg2}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Visibility="{x:Bind BadgeVisibility}">
                                <TextBlock Text="{x:Bind BadgeText}"
                                           FontSize="10"
                                           Foreground="{StaticResource NxTx3}" />
                            </Border>
                            <!-- "P" pill for connections imported from a
                                 Proxmox sync. Lets the user tell managed
                                 rows from manual ones at a glance — paired
                                 with field locks in the editor. -->
                            <Border Background="{StaticResource NxAccent}"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Visibility="{x:Bind ManagedBadgeVisibility}"
                                    ToolTipService.ToolTip="Imported from Proxmox — managed by sync">
                                <TextBlock Text="P"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource NxTx1}" />
                            </Border>
                            <!-- Ping status icon. Color comes from the
                                 PingState enum and only renders when ping
                                 is enabled in settings. -->
                            <Ellipse Width="6" Height="6"
                                     VerticalAlignment="Center"
                                     Visibility="{x:Bind PingIconVisibility, Mode=OneWay}">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{x:Bind PingIconColor, Mode=OneWay}" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{x:Bind LatencyText, Mode=OneWay}"
                                       Visibility="{x:Bind LatencyVisibility, Mode=OneWay}"
                                       FontSize="10"
                                       Foreground="{StaticResource NxTx3}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

    </Grid>
</UserControl>
