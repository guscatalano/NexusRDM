<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.ConnectionsPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:NexusRDM.ViewModels">

    <Grid RowDefinitions="Auto,Auto,*">

        <AutoSuggestBox Grid.Row="0" Margin="8,8,8,0"
            PlaceholderText="Search  (Ctrl+F)" QueryIcon="Find"
            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,4,4,0" Spacing="2">
            <Button Command="{x:Bind ViewModel.NewConnectionCommand}" ToolTipService.ToolTip="New connection">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Add" />
                    <TextBlock Text="New" />
                </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.NewGroupCommand}" ToolTipService.ToolTip="New group">
                <SymbolIcon Symbol="NewFolder" />
            </Button>
            <Button Command="{x:Bind ViewModel.RefreshCommand}" ToolTipService.ToolTip="Refresh">
                <SymbolIcon Symbol="Refresh" />
            </Button>
        </StackPanel>

        <TreeView Grid.Row="2" x:Name="ConnectionTree"
                  ItemsSource="{x:Bind ViewModel.RootItems, Mode=OneWay}"
                  SelectionMode="Single"
                  ItemInvoked="ConnectionTree_ItemInvoked"
                  RightTapped="ConnectionTree_RightTapped">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionTreeNode">
                    <TreeViewItem ItemsSource="{x:Bind Children}" IsExpanded="True">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="14" />
                            <TextBlock Text="{x:Bind DisplayName}" />
                        </StackPanel>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

    </Grid>
</UserControl>
