<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NexusRDM.Views.SftpView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NexusRDM.Core.Models"
    Background="{StaticResource NxBg0}"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch">

    <Grid x:Name="RootGrid" RowDefinitions="30,*,28"
          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
          MinHeight="400">

        <!-- Toolbar — mirrors the SSH session view's style. -->
        <Border Grid.Row="0"
                Background="{StaticResource NxBg1}"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="10,0">
                <Ellipse Grid.Column="0" Width="7" Height="7"
                         Fill="{StaticResource NxAccent}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           x:Name="HostLabel"
                           FontSize="12"
                           Foreground="{StaticResource NxTx2}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="14,0,0,0">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsConnecting, Mode=OneWay}"
                                  Width="14" Height="14"
                                  Foreground="{StaticResource NxAccent}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{StaticResource NxTx2}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                    <Button x:Name="OpenTerminalBtn" Click="OpenTerminal_Click"
                            Background="{StaticResource NxBg2}"
                            BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                            CornerRadius="4" Padding="8,2" FontSize="11"
                            Foreground="{StaticResource NxTx2}"
                            ToolTipService.ToolTip="Open an SSH terminal tab for this host"
                            Content="Terminal" />
                    <Button Command="{x:Bind ViewModel.DisconnectCommand}"
                            Background="{StaticResource NxBg2}"
                            BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                            CornerRadius="4" Padding="8,2" FontSize="11"
                            Foreground="{StaticResource NxTx2}"
                            Content="Disconnect" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Two-pane file manager. The two ListView definitions are
             identical except for the bound collection / commands — the
             local <-> remote symmetry is intentional. -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" Background="{StaticResource NxBg0}">

            <!-- Local pane -->
            <Grid Grid.Column="0" RowDefinitions="28,*">
                <Border Grid.Row="0" Background="{StaticResource NxBg1}"
                        BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1"
                        Padding="8,0">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="Local" FontSize="11"
                                   Foreground="{StaticResource NxTx3}" Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="LocalPathBox"
                                 Text="{x:Bind ViewModel.LocalPath, Mode=TwoWay}"
                                 KeyDown="LocalPathBox_KeyDown"
                                 FontSize="11" Padding="6,2" Margin="0,0,6,0"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{StaticResource NxTx1}" />
                        <Button Grid.Column="2" Content="↑" FontSize="11" Padding="6,2"
                                Click="LocalUp_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,4,0"
                                ToolTipService.ToolTip="Parent folder" />
                        <Button Grid.Column="3" Content="⟳" FontSize="11" Padding="6,2"
                                Click="LocalRefresh_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                                CornerRadius="3" />
                    </Grid>
                </Border>
                <ListView Grid.Row="1" x:Name="LocalList"
                          ItemsSource="{x:Bind ViewModel.LocalEntries}"
                          DoubleTapped="LocalList_DoubleTapped"
                          RightTapped="LocalList_RightTapped"
                          CanDragItems="True"
                          DragItemsStarting="LocalList_DragItemsStarting"
                          AllowDrop="True"
                          DragOver="LocalList_DragOver"
                          Drop="LocalList_Drop"
                          SelectionMode="Single"
                          Background="{StaticResource NxBg0}"
                          BorderThickness="0">
                    <ListView.Header>
                        <Grid ColumnDefinitions="20,*,90,150"
                              Background="{StaticResource NxBg1}"
                              Padding="6,4"
                              BorderBrush="{StaticResource NxBrd}"
                              BorderThickness="0,0,0,1">
                            <TextBlock Grid.Column="1" Text="Name" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}" />
                            <TextBlock Grid.Column="2" Text="Size" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="3" Text="Modified" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <!-- Stretch the per-row Grid to the full
                                 ListView width so all rows share the
                                 same column boundaries; without this
                                 each row sizes to its content and the
                                 columns visibly wobble row-to-row. -->
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="6,2" />
                            <Setter Property="MinHeight" Value="22" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SftpEntry">
                            <Grid ColumnDefinitions="20,*,90,150" VerticalAlignment="Center">
                                <FontIcon Grid.Column="0"
                                          Glyph="{x:Bind IsDirectory, Converter={StaticResource DirectoryGlyphConv}}"
                                          FontSize="11"
                                          Foreground="{StaticResource NxTx3}"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,6,0" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                           FontSize="12" Foreground="{StaticResource NxTx1}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Size, Converter={StaticResource BytesConv}}"
                                           FontSize="11" Foreground="{StaticResource NxTx3}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="{x:Bind LastModified.LocalDateTime}"
                                           FontSize="11" Foreground="{StaticResource NxTx3}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Splitter -->
            <Border Grid.Column="1" Width="1" Background="{StaticResource NxBrd}" />

            <!-- Remote pane -->
            <Grid Grid.Column="2" RowDefinitions="28,*">
                <Border Grid.Row="0" Background="{StaticResource NxBg1}"
                        BorderBrush="{StaticResource NxBrd}" BorderThickness="0,0,0,1"
                        Padding="8,0">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="Remote" FontSize="11"
                                   Foreground="{StaticResource NxTx3}" Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="RemotePathBox"
                                 Text="{x:Bind ViewModel.RemotePath, Mode=TwoWay}"
                                 KeyDown="RemotePathBox_KeyDown"
                                 FontSize="11" Padding="6,2" Margin="0,0,6,0"
                                 BorderThickness="0" Background="Transparent"
                                 Foreground="{StaticResource NxTx1}" />
                        <Button Grid.Column="2" Content="↑" FontSize="11" Padding="6,2"
                                Click="RemoteUp_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,4,0"
                                ToolTipService.ToolTip="Parent folder" />
                        <Button Grid.Column="3" Content="⟳" FontSize="11" Padding="6,2"
                                Click="RemoteRefresh_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,4,0" />
                        <Button Grid.Column="4" Content="New folder" FontSize="11" Padding="6,2"
                                Click="RemoteMkdir_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                                CornerRadius="3" Margin="0,0,4,0" />
                        <Button Grid.Column="5" Content="New file" FontSize="11" Padding="6,2"
                                Click="RemoteNewFile_Click"
                                Background="{StaticResource NxBg2}"
                                BorderBrush="{StaticResource NxBrd}" BorderThickness="1"
                                CornerRadius="3"
                                ToolTipService.ToolTip="Create an empty file in the current remote folder" />
                    </Grid>
                </Border>
                <ListView Grid.Row="1" x:Name="RemoteList"
                          ItemsSource="{x:Bind ViewModel.RemoteEntries}"
                          DoubleTapped="RemoteList_DoubleTapped"
                          RightTapped="RemoteList_RightTapped"
                          CanDragItems="True"
                          DragItemsStarting="RemoteList_DragItemsStarting"
                          AllowDrop="True"
                          DragOver="RemoteList_DragOver"
                          Drop="RemoteList_Drop"
                          SelectionMode="Single"
                          Background="{StaticResource NxBg0}"
                          BorderThickness="0">
                    <ListView.Header>
                        <Grid ColumnDefinitions="20,*,90,150"
                              Background="{StaticResource NxBg1}"
                              Padding="6,4"
                              BorderBrush="{StaticResource NxBrd}"
                              BorderThickness="0,0,0,1">
                            <TextBlock Grid.Column="1" Text="Name" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}" />
                            <TextBlock Grid.Column="2" Text="Size" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="3" Text="Modified" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NxTx3}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <!-- Stretch the per-row Grid to the full
                                 ListView width so all rows share the
                                 same column boundaries; without this
                                 each row sizes to its content and the
                                 columns visibly wobble row-to-row. -->
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="6,2" />
                            <Setter Property="MinHeight" Value="22" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SftpEntry">
                            <Grid ColumnDefinitions="20,*,90,150" VerticalAlignment="Center">
                                <FontIcon Grid.Column="0"
                                          Glyph="{x:Bind IsDirectory, Converter={StaticResource DirectoryGlyphConv}}"
                                          FontSize="11"
                                          Foreground="{StaticResource NxTx3}"
                                          HorizontalAlignment="Left"
                                          Margin="0,0,6,0" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                           FontSize="12" Foreground="{StaticResource NxTx1}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Size, Converter={StaticResource BytesConv}}"
                                           FontSize="11" Foreground="{StaticResource NxTx3}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Text="{x:Bind LastModified.LocalDateTime}"
                                           FontSize="11" Foreground="{StaticResource NxTx3}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- Bottom status bar — transfer progress + batch aggregates. -->
        <Border Grid.Row="2"
                Background="#1E1E28"
                BorderBrush="{StaticResource NxBrd}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="10,0">
                <TextBlock Grid.Column="0" Text="SFTP"
                           Style="{StaticResource StatusTextStyle}" Margin="0,0,12,0" />
                <ProgressBar Grid.Column="1" Width="120"
                             Value="{x:Bind ViewModel.TransferPercent, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.TransferStatus, Mode=OneWay}"
                           Style="{StaticResource StatusTextStyle}"
                           TextTrimming="CharacterEllipsis" MaxWidth="280" />
                <TextBlock Grid.Column="3" Text="{x:Bind ViewModel.BatchProgress, Mode=OneWay}"
                           Style="{StaticResource StatusTextStyle}"
                           Margin="14,0,0,0" />
                <TextBlock Grid.Column="4"
                           Text="{x:Bind ViewModel.QueueDepth, Mode=OneWay}"
                           Style="{StaticResource StatusTextStyle}" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
